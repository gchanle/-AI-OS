# 阿里百炼 DashScope API
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# 可选：覆盖前端模型候选
# DASHSCOPE_MODEL_CANDIDATES=firefly-general-demo,firefly-knowledge-demo,firefly-reasoner-demo,firefly-coder-demo,firefly-lite-demo
# FIREFLY_TASK_EXTRACTION_MODEL=firefly-coder-demo

# 学习通未读消息聚合
CHAOXING_MESSAGE_BASE_URL=https://demo.hall.chaoxing.com
CHAOXING_MESSAGE_FID=anonymous-demo-fid
CHAOXING_MESSAGE_DEFAULT_UID=anonymous-demo-user
CHAOXING_MESSAGE_AES_KEY=replace-with-16-char-aes-key
SERVICE_HALL_MCP_ENDPOINT=https://servicehall.chaoxing.com/homepage/mcp/stream
SERVICE_HALL_MCP_BEARER_TOKEN=replace-with-your-servicehall-token
SERVICE_HALL_MCP_TOKEN_ENDPOINT=https://demo.hall.chaoxing.com/pedestal/auth/createToken
SERVICE_HALL_MCP_FID=anonymous-fid
SERVICE_HALL_MCP_UID=anonymous-uid
SERVICE_HALL_MCP_AES_KEY=replace-with-16-char-key

# 审批记录接口签名（不同 fid 可能不同）
# CHAOXING_APPROVAL_RECORD_SIGN=approveData_demo
# CHAOXING_APPROVAL_RECORD_KEY=DEMO_APPROVAL_KEY

# 当前用户默认资料（后续可替换为真实登录用户上下文）
# CURRENT_CAMPUS_USER_NAME=Campus Demo Admin
# CURRENT_CAMPUS_USER_AVATAR=/user-avatar.png
